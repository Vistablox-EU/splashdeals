{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "server/actions/**/*.ts",
    "scripts/check-*.mjs",
    "scripts/eslint-import-fix.mjs",
    "scripts/migrate-ticket-hierarchy.ts"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "server/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "config/**/*.{ts,tsx}"
  ],
  "ignore": [
    "app/(dashboard)/admin/_common/**",
    "app/(dashboard)/admin/users/_components/**",
    "components/ui/*.tsx"
  ]
}
