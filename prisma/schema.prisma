generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["admin", "marketing", "partners", "public", "sales"]
}

model User {
  id               String                    @id @default(cuid())
  name             String?
  email            String                    @unique
  emailVerified    Boolean                   @default(false)
  image            String?
  role             UserRole                  @default(CUSTOMER)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  accounts         Account[]
  sessions         Session[]
  apiKeys          ApiKey[]
  transactions     Transaction[]
  amenityAuditLogs AmenityAuditLog[]
  staffAssignments FacilityStaffAssignment[]
  facilityOwners   FacilityOwner[]
  cartSessions     CartSession[]
  reviews          Review[]

  @@schema("admin")
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  key        String    @unique // hashed
  prefix     String // first 8 chars for identification
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("api_keys")
  @@schema("admin")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@schema("admin")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("admin")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier])
  @@schema("admin")
}

model Facility {
  id                String                    @id @default(uuid())
  name              String
  slug              String                    @unique
  category          String
  city              String
  cityId            String?
  primaryCity       City?                     @relation(fields: [cityId], references: [id], name: "facilityCityRel")
  streetName        String
  streetNumber      String
  postalCode        String
  lat               Float?
  lng               Float?
  status            FacilityStatus            @default(DRAFT)
  metaTitle         String?
  metaDescription   String?
  logoUrl           String?
  description       String?                   @db.Text
  publicPhone       String?
  publicEmail       String?
  socialLinks       Json?
  emergencyContact  String?
  seoArticle        String?                   @db.Text
  transitGuide      String?                   @db.Text
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  amenities         FacilityAmenity[]
  marketplaceCities FacilityCity[]
  media             FacilityMedia[]
  policy            FacilityPolicy?
  hours             OperatingHours[]
  payoutProfile     PayoutProfile?
  ticketCategories  TicketCategory[]
  revenue           Transaction[]
  closures          FacilityClosure[]
  faqs              FacilityFAQ[]
  labels            FacilityLabel[]
  staffAssignments  FacilityStaffAssignment[]
  owners            FacilityOwner[]
  products          Product[]
  campaignLinks     CampaignFacility[]
  reviews           Review[]
  pageViews         FacilityPageView[]

  @@schema("partners")
}

/// 🏢 Links FACILITY_STAFF users to the specific facilities they can manage
model FacilityStaffAssignment {
  id         String   @id @default(cuid())
  userId     String
  facilityId String
  assignedAt DateTime @default(now())
  assignedBy String // userId of the SUPER_ADMIN who assigned this

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([userId, facilityId])
  @@index([facilityId])
  @@index([userId])
  @@map("facility_staff_assignments")
  @@schema("partners")
}

/// 🏪 Links FACILITY_OWNER users to the specific facilities they own
model FacilityOwner {
  userId     String
  facilityId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([userId, facilityId])
  @@schema("partners")
}

model FacilityClosure {
  id          String   @id @default(uuid())
  facilityId  String
  startDate   DateTime
  endDate     DateTime
  reason      String?
  isEmergency Boolean  @default(false)
  createdAt   DateTime @default(now())
  facility    Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@map("facility_closures")
  @@schema("partners")
}

model Amenity {
  id         String            @id @default(uuid())
  name       String            @unique
  icon       String            @default("Waves")
  category   String?
  isSeeded   Boolean           @default(false)
  type       AmenityValueType  @default(BOOLEAN)
  facilities FacilityAmenity[]

  @@schema("partners")
}

model FacilityAmenity {
  facilityId   String
  amenityId    String
  value        String?
  imageUrl     String?
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  isFeatured   Boolean   @default(false)
  scheduledAt  DateTime?
  updatedAt    DateTime  @default(now()) @updatedAt

  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([facilityId, amenityId])
  @@schema("partners")
}

model AmenityAuditLog {
  id               String   @id @default(uuid())
  targetFacilityId String
  amenityId        String
  action           String
  oldValue         String?
  newValue         String?
  userId           String?
  createdAt        DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([targetFacilityId])
  @@map("amenity_audit_logs")
  @@schema("partners")
}

model FacilityMedia {
  id               String       @id @default(uuid())
  facilityId       String
  url              String
  thumbnailUrl     String?
  originalUrl      String?
  type             MediaType    @default(PHOTO)
  purpose          MediaPurpose @default(GALLERY)
  caption          String?
  order            Int          @default(0)
  focalPoint       String?
  isHero           Boolean      @default(false)
  isCardBackground Boolean      @default(false)
  isGalleryVisible Boolean      @default(true)
  createdAt        DateTime     @default(now())
  facility         Facility     @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId, order])
  @@index([facilityId, isHero])
  @@index([facilityId, isGalleryVisible])
  @@schema("partners")
}

model OperatingHours {
  id         String   @id @default(uuid())
  facilityId String
  dayOfWeek  Int
  openTime   String   @db.Text
  closeTime  String   @db.Text
  isClosed   Boolean  @default(false)
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId, dayOfWeek])
  @@schema("partners")
}

model FacilityPolicy {
  id         String   @id @default(uuid())
  facilityId String   @unique
  rules      String   @db.Text
  faq        String?
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@schema("partners")
}

model PayoutProfile {
  id              String   @id @default(uuid())
  facilityId      String   @unique
  stripeAccountId String?  @unique
  commissionRate  Decimal  @default(5.00) @db.Decimal(4, 2)
  bankName        String?
  iban            String?
  facility        Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@schema("partners")
}

model City {
  id              String         @id @default(uuid())
  name            String
  slug            String         @unique
  facilities      FacilityCity[]
  facilityPrimary Facility[]     @relation(name: "facilityCityRel")

  @@schema("partners")
}

model FacilityCity {
  facilityId String
  cityId     String
  isPrimary  Boolean  @default(false)
  city       City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([facilityId, cityId])
  @@schema("partners")
}

/// Kategorija — "Ulaznice", "Sezonske Karte"
model TicketCategory {
  id           String   @id @default(uuid())
  facilityId   String
  title          String
  slug           String?
  displayOrder   Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  facility Facility     @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  types    TicketProduct[]

  @@unique([facilityId, slug])
  @@index([facilityId])
  @@schema("partners")
}

/// Tip — "Odrasli", "Deca", "Penzioneri" — shared metadata
model TicketProduct {
  id               String       @id @default(uuid())
  categoryId       String
  title            String
  label            String?
  description      String?
  imageUrl         String?
  slug             String?
  displayOrder     Int          @default(0)
  isActive         Boolean      @default(true)
  requiresIdentity Boolean      @default(false)
  requiresPhoto    Boolean      @default(false)
  minPeople        Int          @default(1)
  maxPeople        Int?
  isSeasonPass     Boolean      @default(false)
  validityType     ValidityType @default(FLEXIBLE_30_DAY)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  category TicketCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  prices   TicketPrice[]

  @@index([categoryId, isActive])
  @@schema("partners")
}

/// Cena — konkretna varijanta dayType × timeSlot × cena
model TicketPrice {
  id            String       @id @default(uuid())
  ticketTypeId  String
  label         String?
  displayOrder  Int          @default(0)
  isActive      Boolean      @default(true)
  price         Decimal      @db.Decimal(10, 2)
  originalPrice Decimal?     @db.Decimal(10, 2)
  dayType       DayType?     @default(ALL)
  timeSlot      TimeSlot?    @default(FULL_DAY)
  validFrom     DateTime?
  validTo       DateTime?
  saleStart     DateTime?
  saleEnd       DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  ticketType    TicketProduct    @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  issuedTickets IssuedTicket[]

  @@index([ticketTypeId, isActive, dayType, timeSlot])
  @@schema("partners")
}

model Transaction {
  id               String         @id @default(uuid())
  userId           String
  facilityId       String
  stripeSession    String         @unique
  totalAmount      Decimal        @db.Decimal(10, 2)
  currency         String         @default("RSD")
  status           String         @default("PENDING")
  receiptPdfUrl    String?
  ticketDetails    Json?          // snapshot: [{ type, price, dayType, timeSlot }] at time of purchase
  createdAt        DateTime       @default(now())
  fulfillmentError Json?
  issuedTickets    IssuedTicket[]
  facility         Facility       @relation(fields: [facilityId], references: [id])
  user             User           @relation(fields: [userId], references: [id])

  @@index([status])
  @@schema("sales")
}

model Product {
  id            String   @id @default(uuid())
  facilityId    String
  name          String
  description   String?
  price         Decimal  @db.Decimal(10, 2)
  currency      String   @default("RSD")
  inventory     Int?
  imageUrl      String?
  isActive      Boolean  @default(true)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
  @@map("products")
  @@schema("partners")
}

model IssuedTicket {
  id             String       @id @default(uuid())
  qrHash         String       @unique
  ticketPriceId  String
  transactionId  String
  status         TicketStatus @default(ACTIVE)
  usageCount     Int          @default(0)
  usageLimit     Int          @default(1)
  expiryDate     DateTime
  holderName     String?
  holderPhotoUrl String?

  ticketPrice TicketPrice  @relation(fields: [ticketPriceId], references: [id], onDelete: Restrict)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@schema("sales")
}

model CartSession {
  id        String   @id @default(uuid())
  userId    String
  items     Json
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("sales")
}

model Campaign {
  id                String   @id @default(uuid())
  name              String
  code              String?  @unique
  discountPercent   Decimal  @db.Decimal(5, 2)
  minPurchaseAmount Decimal? @db.Decimal(10, 2)
  validFrom         DateTime
  validTo           DateTime
  usageLimit        Int?
  usedCount         Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  facilityRestrictions CampaignFacility[]

  @@index([createdAt])
  @@map("campaigns")
  @@schema("marketing")
}

model CampaignFacility {
  campaignId String
  facilityId String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([campaignId, facilityId])
  @@map("campaign_facilities")
  @@schema("marketing")
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
  source    String?

  @@map("subscriber")
  @@schema("marketing")
}

// --- CMS Blog i Page modeli ---

model BlogPost {
  id            String    @id @default(uuid())
  title         String
  slug          String    @unique
  excerpt       String?   @db.Text
  content       String    @db.Text
  coverImage    String?
  featuredImage String?
  authorId      String?
  author        String?
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  /// SEO polja
  metaTitle       String?
  metaDescription String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  canonicalUrl    String?
  robotsDirective String?
  schemaMarkup    Json?

  /// Status i organizacija
  status      PostStatus    @default(DRAFT)
  categoryId  String?
  category    BlogCategory? @relation(fields: [categoryId], references: [id])
  tags            BlogPostTag[]
  revisions       BlogPostRevision[]
  isFeatured      Boolean      @default(false)
  readingTime Int?
  expiresAt  DateTime?
  reviewedAt DateTime?

  @@index([status, publishedAt])
  @@index([slug])
  @@map("blog_posts")
  @@schema("marketing")
}

model BlogCategory {
  id           String     @id @default(uuid())
  name         String
  slug         String     @unique
  description  String?
  color        String?
  displayOrder Int        @default(0)
  posts        BlogPost[]

  @@map("blog_categories")
  @@schema("marketing")
}

model BlogTag {
  id    String        @id @default(uuid())
  name  String        @unique
  slug  String        @unique
  posts BlogPostTag[]

  @@map("blog_tags")
  @@schema("marketing")
}

model BlogPostTag {
  postId String
  tagId  String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@schema("marketing")
}

/// 📝 Auto-saved content revisions on publish
model BlogPostRevision {
  id        String   @id @default(uuid())
  postId    String
  title     String
  content   String   @db.Text
  excerpt   String?  @db.Text
  createdAt DateTime @default(now())
  createdBy String?

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("blog_post_revisions")
  @@schema("marketing")
}

model Page {
  id         String  @id @default(uuid())
  title      String
  slug       String  @unique
  content    String  @db.Text
  excerpt    String? @db.Text
  coverImage String?

  /// SEO polja
  metaTitle       String?
  metaDescription String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  canonicalUrl    String?
  robotsDirective String?

  /// Layout opcije
  template   String  @default("default")
  showHeader Boolean @default(true)
  showFooter Boolean @default(true)

  /// Status
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  expiresAt  DateTime?
  reviewedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([slug, status])
  @@map("pages")
  @@schema("marketing")
}

/// 📁 CMS media library — uploaded images for blog posts and pages
model CmsMedia {
  id         String    @id @default(uuid())
  url        String    @unique
  filename   String
  size       Int
  mimeType   String
  fileHash   String?
  altText    String?
  width      Int?
  height     Int?
  collection String?
  deletedAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([createdAt])
  @@index([deletedAt])
  @@index([fileHash])
  @@map("cms_media")
  @@schema("marketing")
}

enum PostStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED

  @@schema("marketing")
}

/// 🧩 How a mega menu section renders in the panel
enum NavigationSectionStyle {
  LINKS           // icon + title + desc links
  DOT_LINKS       // bullet-dot links without icons
  DYNAMIC_CITIES  // auto-populated from /api/menu/discovery
  FOOTER_BADGE    // static icon + text with border-top
  VISUAL          // branded visual block (scanner mockup, club card)

  @@schema("marketing")
}

/// 🧭 Top-level tab in the mega menu (Istraži, Za Biznis, Korisnici, Blog)
model NavigationMenu {
  id        String   @id @default(uuid())
  label     String
  icon      String
  placement String   @default("left")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sections NavigationMenuSection[]

  @@map("navigation_menus")
  @@schema("marketing")
}

/// 📦 A section/group inside a menu's panel
/// Renders as: <h4>heading</h4> + items rendered per style
model NavigationMenuSection {
  id        String   @id @default(uuid())
  menuId    String
  menu      NavigationMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  heading   String?                // null → no <h4> rendered
  column    Int      @default(0)   // 0, 1, 2 — which grid column
  style     NavigationSectionStyle
  config    Json?                  // Per-style config (footer icon, visual component, city slugs)
  sortOrder Int      @default(0)   // Within its column
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items NavigationMenuItem[]

  @@index([menuId, column, sortOrder])
  @@map("navigation_menu_sections")
  @@schema("marketing")
}

/// 🔗 A single link/item inside a section
model NavigationMenuItem {
  id        String   @id @default(uuid())
  sectionId String
  section   NavigationMenuSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  label     String
  href      String?                // null for visual blocks
  icon      String?
  desc      String?

  /// Rich metadata — badges, price, variant, thumbnail, count, accent, external
  metadata  Json?

  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectionId, sortOrder])
  @@map("navigation_menu_items")
  @@schema("marketing")
}

enum UserRole {
  CUSTOMER
  FACILITY_STAFF
  FACILITY_OWNER
  SUPER_ADMIN

  @@schema("admin")
}

enum FacilityStatus {
  DRAFT
  ACTIVE
  CLOSED
  EMERGENCY_SHUTDOWN

  @@schema("partners")
}

enum MediaType {
  PHOTO
  VIDEO

  @@schema("partners")
}

enum MediaPurpose {
  GALLERY
  HERO_ONLY
  TICKET
  AERIAL
  LOGO
  MENU

  @@schema("partners")
}

enum TicketType {
  ADULT
  CHILD
  SENIOR
  STUDENT
  FAMILY_BUNDLE
  SUMMER_PASS

  @@schema("partners")
}

enum ValidityType {
  FIXED_DATE
  FLEXIBLE_30_DAY
  SUMMER_SEASON

  @@schema("partners")
}

enum TicketStatus {
  ACTIVE
  USED
  EXPIRED
  CREDIT_ELIGIBLE
  HOLD

  @@schema("sales")
}

/// Naseljeno mesto u Srbiji — koristi se za autocomplete i označavanje objekata
model PopulatedPlace {
  id            String   @id @default(uuid())
  name          String
  type          String?                 // "Grad" | "Varosica" | "Selo" | "Mesna Zajednica"
  municipality  String?                 // Opština
  district      String?                 // Okrug
  region        String?                 // "Vojvodina" | "Centralna Srbija" | "Kosovo"
  postalCode    String?
  latitude      Float?
  longitude     Float?
  slug          String   @unique
  createdAt     DateTime @default(now())
  labels        FacilityLabel[]

  @@index([name])
  @@index([municipality])
  @@index([district])
  @@schema("partners")
  @@map("populated_places")
}

/// Oznaka grada/mesta za objekat — povezuje Facility sa PopulatedPlace
model FacilityLabel {
  id         String          @id @default(uuid())
  facilityId String
  facility   Facility        @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  placeId    String
  place      PopulatedPlace  @relation(fields: [placeId], references: [id])
  label      String?                 // prikazni naziv (može se menjadi)
  isPrimary  Boolean         @default(false)
  createdAt  DateTime        @default(now())

  @@unique([facilityId, placeId])
  @@index([facilityId])
  @@index([placeId])
  @@schema("partners")
  @@map("facility_labels")
}

/// Pitanja i odgovori za objekat — prikazuju se na javnoj stranici objekta
/// 📊 Daily page view counter for facility analytics dashboard
model FacilityPageView {
  id         String   @id @default(uuid())
  facilityId String
  date       DateTime // normalized to start of day (00:00:00 UTC)
  count      Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([facilityId, date])
  @@index([facilityId, date])
  @@map("facility_page_views")
  @@schema("partners")
}

model FacilityFAQ {
  id           String   @id @default(uuid())
  facilityId   String
  facility     Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  question     String
  answer       String   @db.Text
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([facilityId, displayOrder])
  @@schema("partners")
  @@map("facility_faqs")
}

/// ⭐ Reviews — user reviews for facilities
model Review {
  id         String   @id @default(uuid())
  facilityId String
  userId     String
  rating     Int      // 1-5
  title      String?
  content    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([facilityId, userId]) // one review per user per facility
  @@map("reviews")
  @@schema("partners")
}

enum AmenityValueType {
  QUANTIFIABLE
  BOOLEAN
  TEXT

  @@schema("partners")
}

enum DayType {
  WEEKDAY
  WEEKEND
  HOLIDAY
  ALL

  @@schema("partners")
}

enum TimeSlot {
  FULL_DAY
  AFTER_16H
  THREE_HOUR

  @@schema("partners")
}

/// Webhooks for CMS content events
model Webhook {
  id                   String       @id @default(uuid())
  name                 String
  url                  String
  events               String[]
  isActive             Boolean      @default(true)
  consecutiveFailures  Int          @default(0)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  logs WebhookLog[]

  @@schema("marketing")
}

model WebhookLog {
  id           String   @id @default(uuid())
  webhookId    String
  event        String
  status       String
  responseCode Int?
  responseBody String?
  createdAt    DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@schema("marketing")
}

/// Search analytics — zero-result query tracking
model SearchLog {
  id        String   @id @default(uuid())
  query     String
  results   Int
  createdAt DateTime @default(now())

  @@schema("marketing")
}

/// 📋 Activity log for CMS audit trail
model ActivityLog {
  id         String   @id @default(uuid())
  userId     String
  action     String   // "post.created", "post.updated", "post.published", "post.deleted", etc.
  entityId   String?
  entityType String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
  @@schema("marketing")
}

/// 🔀 URL redirect manager
model Redirect {
  id          String   @id @default(uuid())
  source      String   @unique
  destination String
  statusCode  Int      @default(301)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([source, isActive])
  @@map("redirects")
  @@schema("marketing")
}
